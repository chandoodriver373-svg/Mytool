#!/data/data/com.termux/files/usr/bin/bash

case "$1" in

  help)
    echo "=== MyTool ==="
    echo "Commands:"
    echo "  help"
    echo "  joke"
    echo "  quote"
    echo "  pass"
    echo "  notes add TEXT"
    echo "  notes list"
    echo "  calc EXPRESSION"
    echo "  date"
    echo "  uuid"
    echo "  sysinfo"
    ;;

  joke)
    echo "Programmer joke:"
    echo "It works on my machine 😎"
    ;;

  quote)
    echo "Keep learning one step at a time."
    ;;

  pass)
    tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 12
    echo
    ;;

  notes)
    if [ "$2" = "add" ]; then
      shift 2
      echo "$*" >> "$HOME/mytool_notes.txt"
      echo "Note saved."
    elif [ "$2" = "list" ]; then
      cat "$HOME/mytool_notes.txt" 2>/dev/null || echo "No notes yet."
    fi
    ;;

  calc)
    echo "$2" | bc
    ;;

  date)
    date
    ;;

  uuid)
    cat /proc/sys/kernel/random/uuid
    ;;

  sysinfo)
    echo "Model: $(getprop ro.product.model)"
    echo "Android: $(getprop ro.build.version.release)"
    echo "CPU: $(uname -m)"
    ;;

  *)
    echo "Unknown command."
    echo "Try: mytool help"
    ;;

esac
